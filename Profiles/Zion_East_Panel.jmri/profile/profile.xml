<?xml version="1.0" encoding="UTF-8"?>
<auxiliary-configuration xmlns="http://www.netbeans.org/ns/auxiliary-configuration/1">
    <connections xmlns="http://jmri.org/xml/schema/auxiliary-configuration/connections-2-9-6.xsd">
        <connection xmlns="" class="jmri.jmrix.can.adapters.gridconnect.lccbuffer.serialdriver.configurexml.ConnectionConfigXml" disabled="no" manufacturer="LCC" port="ttyACM0" reconnectMaxAttempts="100" reconnectMaxInterval="120" speed="57600" systemPrefix="M" turnoutInterval="100" userName="LCC">
            <options>
                <option>
                    <name>Protocol</name>
                    <value>OpenLCB</value>
                </option>
            </options>
            <node name="Ident">
                <parameter name="UserName">Zion East RPi</parameter>
                <parameter name="NodeId"/>
                <parameter name="UserDescription">Drives the touchscreen panel</parameter>
            </node>
            <node name="FastClock">
                <parameter name="EnableMode">disabled</parameter>
                <parameter name="ClockCustomId"/>
                <parameter name="ClockId">default</parameter>
            </node>
        </connection>
    </connections>
    <startup xmlns="http://jmri.org/xml/schema/auxiliary-configuration/startup-4-3-5.xsd">
