        <perform xmlns="" class="apps.startup.configurexml.ScriptButtonModelXml" enabled="yes" name="Restart RPi" type="Button">
            <property name="script" value="scripts:RaspberryPiRestart.py"/>
        </perform>
        <perform xmlns="" class="apps.startup.configurexml.ScriptButtonModelXml" enabled="yes" name="Shutdown RPi" type="Button">
            <property name="script" value="scripts:RaspberryPiShutdown.py"/>
        </perform>
        <perform xmlns="" class="jmri.util.startup.configurexml.PerformScriptModelXml" enabled="yes" name="scripts:LCC/ChangeDefaultBackupFileName.py" type="ScriptFile"/>
        <perform xmlns="" class="jmri.util.startup.configurexml.PerformFileModelXml" enabled="yes" name="preference:ZionE-Development.xml" type="XmlFile"/>
        <perform xmlns="" class="jmri.util.startup.configurexml.PerformScriptModelXml" enabled="yes" name="preference:ZionE-Setup.py" type="ScriptFile"/>
        <perform xmlns="" class="jmri.util.startup.configurexml.PerformScriptModelXml" enabled="yes" name="preference:ZionE_NXlogic.py" type="ScriptFile"/>
